# Shared runtime
NODE_ENV=development

# Backend database configuration (local fallback)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fixapp_dev
DB_USER=postgres
DB_PASSWORD=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/fixapp_dev
POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@localhost:5432/fixapp_dev
MIGRATIONS_DB_URL=postgresql://postgres:postgres@localhost:5432/fixapp_dev

# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend application
PORT=3001
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
GRPC_PORT=50051

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend application
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Production examples
# NEXT_PUBLIC_BACKEND_URL=https://api.fixapp.com
# NEXTAUTH_URL=https://app.fixapp.com
# NEXT_PUBLIC_APP_URL=https://app.fixapp.com
# CORS_ORIGIN=https://app.fixapp.com
# APP_URL=https://app.fixapp.com
# PORT=8080
